<nav class="navbar navbar-expand-lg navbar-custom sticky-top">

    <div class="container">

        <a class="navbar-brand brand" href="{{ path('app_home') }}">

            <div class="brand-logo">
                HB
            </div>

            <div class="brand-text">
                <span class="brand-title">
                    HOTEL BOOKING
                </span>

                <span class="brand-subtitle">
                    Reservation
                </span>
            </div>

        </a>

        <button
