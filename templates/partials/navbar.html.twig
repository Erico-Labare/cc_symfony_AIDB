                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            <ul class="navbar-nav mx-auto">

                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}"
                       href="{{ path('app_home') }}">
                        Accueil
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_reservation' ? 'active' : '' }}"
                       href="{{ path('app_reservation_search') }}">
                        Réserver
                    </a>
                </li>

                {% if app.user %}

                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_client' ? 'active' : '' }}"
                           href="{{ path('app_client_profile') }}">
