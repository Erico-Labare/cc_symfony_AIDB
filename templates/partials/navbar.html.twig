                        </a>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}

                        <li class="nav-item">
                            <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_admin' ? 'active' : '' }}"
                               href="{{ path('app_admin') }}">
