{% extends 'base.html.twig' %}

{% block title %}Modifier le mot de passe{% endblock %}

{% block body %}

<section class="profile-page">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Modifier le mot de passe
        </h1>

        <p class="page-subtitle">
            Sécurisez votre compte en définissant un nouveau mot de passe.
        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="reservation-card">

                {{ form_start(form) }}

                    <div class="mb-4">

                        {{ form_label(form.currentPassword, 'Mot de passe actuel', {
                            label_attr: { class: 'form-label fw-semibold' }
                        }) }}

                        {{ form_widget(form.currentPassword, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Saisissez votre mot de passe actuel'
                            }
                        }) }}

                        {{ form_errors(form.currentPassword) }}

                    </div>

                    <div class="mb-4">

                        {{ form_label(form.plainPassword.first, 'Nouveau mot de passe', {
                            label_attr: { class: 'form-label fw-semibold' }
                        }) }}

                        {{ form_widget(form.plainPassword.first, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Choisissez un nouveau mot de passe'
                            }
                        }) }}

                        {{ form_errors(form.plainPassword.first) }}

                    </div>

                    <div class="mb-4">

                        {{ form_label(form.plainPassword.second, 'Confirmation du mot de passe', {
                            label_attr: { class: 'form-label fw-semibold' }
                        }) }}

                        {{ form_widget(form.plainPassword.second, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Confirmez le nouveau mot de passe'
                            }
                        }) }}

                        {{ form_errors(form.plainPassword.second) }}

                    </div>

                    <div class="reservation-actions mt-4">

                        <a
                            href="{{ path('app_client_profile') }}"
                            class="btn btn-outline-secondary">

                            <i class="bi bi-arrow-left"></i>

                            Retour au profil

                        </a>

                        <button
                            type="submit"
                            class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>

                            Enregistrer

                        </button>

                    </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</section>

{% endblock %}