{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
    <h1>Mon profil</h1>

    <p class="text-muted">Email du compte : <strong>{{ compte.email }}</strong></p>

    {% if client is not null %}
        <div class="card shadow-sm mt-3">
            <div class="card-body">
                <h5 class="card-title">Informations client</h5>

                <p class="card-text mb-1">
                    <strong>Nom :</strong> {{ client.nom }}
                </p>
                <p class="card-text mb-1">
                    <strong>Email :</strong> {{ client.email }}
                </p>
                <p class="card-text mb-1">
                    <strong>Adresse :</strong> {{ client.adresse }}
                </p>
                <p class="card-text mb-0">
                    <strong>Téléphone :</strong> {{ client.telephone }}
                </p>
                <a href="#" class="btn btn-warning disabled">
                    Modifier mon profil
                </a>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning mt-3">
            <p class="mb-0">Votre profil client n'est pas encore complété.</p>
        </div>
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_reservation_my_reservations') }}" class="btn btn-primary">Mes réservations</a>
        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Accueil</a>
    </div>
{% endblock %}
