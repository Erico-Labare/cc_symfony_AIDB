{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="card-title mb-4">Mon compte</h1> {# Changed h5 to h1 #}

            {# Removed the conditional display of client.nom #}
            <p class="card-text mb-2">
                <strong>Nom d'utilisateur / Email :</strong> {{ compte.email }} {# Renamed label #}
            </p>
            <p class="card-text mb-2">
                <strong>Type de compte :</strong> {# Renamed label #}
                {% if 'ROLE_ADMIN' in compte.roles %}
                    Administrateur
                {% else %}
                    Utilisateur
                {% endif %}
            </p>
            <p class="card-text mb-4">
                <strong>Mot de passe :</strong> ************
            </p>

            <a href="{{ path('app_client_change_password') }}" class="btn btn-warning">Changer mon mot de passe</a>
            <a href="{{ path('app_reservation_my_reservations') }}" class="btn btn-primary">Mes réservations</a>
            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Retour à l'accueil</a>
        </div>
    </div>
{% endblock %}
