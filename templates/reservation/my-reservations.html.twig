{% extends 'base.html.twig' %}

{% block title %}Mes réservations{% endblock %}

{% block body %}

<section class="reservation-page">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Mes réservations
        </h1>

        <p class="page-subtitle">

            {{ reservations|length }}

            réservation(s) enregistrée(s)

        </p>

    </div>

    {% if reservations is not empty %}

        <div class="row g-4">

            {% for reservation in reservations %}

                <div class="col-lg-6">

                    <div class="reservation-card">

                        <div class="reservation-header">

                            <span class="reservation-number">

                                Réservation #{{ reservation.id }}

                            </span>

                            <span class="room-badge">

                                {{ reservation.chambre.type }}

                            </span>

                        </div>

                        <div class="reservation-section">

                            <h5>

                                <i class="bi bi-building"></i>

                                {{ reservation.chambre.hotel.nom }}

                            </h5>

                        </div>

                        <div class="reservation-info">

                            <p>

                                <i class="bi bi-door-open"></i>

                                Chambre {{ reservation.chambre.id }}

                            </p>

                            <p>

                                <i class="bi bi-layers"></i>

                                Étage {{ reservation.chambre.etage }}

                            </p>

                            <p>

                                <i class="bi bi-calendar-event"></i>

                                {{ reservation.dateDebut|date('d/m/Y') }}

                                →

                                {{ reservation.dateFin|date('d/m/Y') }}

                            </p>

                        </div>

                        <hr>

                        <div class="traveler-card">

                            <h6>

                                <i class="bi bi-person-circle"></i>

                                Voyageur

                            </h6>

                            <strong>

                                {{ reservation.client.nom }}

                            </strong>

                            <div class="small text-muted mt-2">

                                {{ reservation.client.email }}

                            </div>

                            <div class="small text-muted">

                                {{ reservation.client.telephone }}

                            </div>

                        </div>

                        <hr>

                        <div class="comment-box">

                            <h6>

                                <i class="bi bi-chat-left-text"></i>

                                Demandes particulières

                            </h6>

                            {% if reservation.commentaire %}

                                <p>

                                    {{ reservation.commentaire }}

                                </p>

                            {% else %}

                                <p class="text-muted fst-italic">

                                    Aucun commentaire.

                                </p>

                            {% endif %}

                        </div>

                        <div class="reservation-actions">

                            <a
                                href="{{ path('app_reservation_comment_edit', {'id': reservation.id}) }}"
                                class="btn btn-primary">

                                <i class="bi bi-pencil-square"></i>

                                Modifier

                            </a>

                            <form
                                method="post"
                                action="{{ path('app_reservation_cancel', {'id': reservation.id}) }}"
                                onsubmit="return confirm('Voulez-vous vraiment annuler cette réservation ?');">

                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('cancel' ~ reservation.id) }}">

                                <button
                                    class="btn btn-outline-danger">

                                    <i class="bi bi-trash"></i>

                                    Annuler

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% else %}

        <div class="empty-reservation">

            <i class="bi bi-calendar-x"></i>

            <h3>

                Vous n'avez encore effectué aucune réservation.

            </h3>

            <a
                href="{{ path('app_reservation_search') }}"
                class="btn btn-primary btn-lg mt-3">

                Réserver une chambre

            </a>

        </div>

    {% endif %}

</section>

{% endblock %}