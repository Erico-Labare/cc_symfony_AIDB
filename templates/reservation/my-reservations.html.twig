{% extends 'base.html.twig' %}

{% block title %}Mes réservations{% endblock %}

{% block body %}
    <h1>Mes réservations</h1>

    {% if reservations is not empty %}
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Numéro de réservation</th>
                    <th>Chambre</th>
                    <th>Hôtel</th>
                    <th>Date de début</th>
                    <th>Date de fin</th>
                    <th>Client (Nom)</th>
                    <th>Client (Email)</th>
                    <th>Client (Téléphone)</th>
                    <th>Commentaire</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                    <tr>
                        <td>#{{ reservation.id }}</td>
                        <td>{{ reservation.chambre.id }} ({{ reservation.chambre.type }})</td>
                        <td>{{ reservation.chambre.hotel.nom }}</td>
                        <td>{{ reservation.dateDebut|date('d/m/Y') }}</td>
                        <td>{{ reservation.dateFin|date('d/m/Y') }}</td>
                        <td>{{ reservation.client.nom }}</td>
                        <td>{{ reservation.client.email }}</td>
                        <td>{{ reservation.client.telephone|default('-') }}</td>
                        <td>{{ reservation.commentaire|default('-') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="alert alert-info">
            <p>Vous n'avez aucune réservation pour le moment.</p>
            <a href="{{ path('app_reservation_search') }}" class="btn btn-primary">Rechercher une chambre</a>
        </div>
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_reservation_search') }}" class="btn btn-secondary">Retour à la recherche</a>
        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">Accueil</a>
    </div>
{% endblock %}
