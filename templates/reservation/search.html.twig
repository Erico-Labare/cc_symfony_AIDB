{% extends 'base.html.twig' %}

{% block title %}Rechercher une chambre{% endblock %}

{% block body %}
    <h1>Rechercher une chambre disponible</h1>

    {{ form_start(form) }}
        <div class="form-group mb-3">
            {{ form_label(form.hotel) }}
            {{ form_widget(form.hotel, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.hotel) }}
        </div>

        <div class="form-group mb-3">
            {{ form_label(form.dateDebut, 'Date de début') }}
            {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateDebut) }}
        </div>

        <div class="form-group mb-3">
            {{ form_label(form.dateFin, 'Date de fin') }}
            {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateFin) }}
        </div>

        <button type="submit" class="btn btn-primary">Rechercher</button>
    {{ form_end(form) }}

    {% if availableRooms is not empty %}
        <h2 class="mt-5">Chambres disponibles</h2>

        {% if is_granted('ROLE_USER') %}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Numéro</th>
                        <th>Type</th>
                        <th>Nombre de lits</th>
                        <th>Étage</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for chambre in availableRooms %}
                        <tr>
                            <td>{{ chambre.id }}</td>
                            <td>{{ chambre.type }}</td>
                            <td>{{ chambre.nombreLit }}</td>
                            <td>{{ chambre.etage }}</td>
                            <td>
                                <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#reservationModal{{ chambre.id }}">
                                    Réserver
                                </button>
                            </td>
                        </tr>

                        <!-- Modal de réservation -->
                        <div class="modal fade" id="reservationModal{{ chambre.id }}" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Réserver la chambre {{ chambre.id }}</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post" action="{{ path('app_reservation_create') }}">
                                        <div class="modal-body">
                                            <input type="hidden" name="chambre_id" value="{{ chambre.id }}">
                                            <input type="hidden" name="dateDebut" value="{{ form.dateDebut.vars.value|date('Y-m-d') }}">
                                            <input type="hidden" name="dateFin" value="{{ form.dateFin.vars.value|date('Y-m-d') }}">
                                            <div class="mb-3">
                                                <label for="client_select_{{ chambre.id }}" class="form-label">
                                                    Client
                                                </label>
                                                <div class="alert alert-info py-2">
                                                    Si le client existe déjà, sélectionnez-le dans la liste.
                                                    Sinon laissez <strong>"Nouveau client"</strong> puis remplissez le formulaire.
                                                </div>
                                                <select
                                                    class="form-select client-select"
                                                    id="client_select_{{ chambre.id }}"
                                                    name="client_id"
                                                >
                                                    <option value="">
                                                        -- Nouveau client --
                                                    </option>

                                                    {% for client in clients %}
                                                        <option
                                                            value="{{ client.id }}"
                                                            data-nom="{{ client.nom }}"
                                                            data-email="{{ client.email }}"
                                                            data-telephone="{{ client.telephone }}"
                                                            data-adresse="{{ client.adresse }}"
                                                        >
                                                            {{ client.nom }} - ({{ client.email }})
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            </div>
            
                                            <h6 class="mt-3">Informations du client pour cette réservation</h6>
                                            <div class="mb-3">
                                                <label for="client_nom_{{ chambre.id }}" class="form-label">Nom</label>
                                                <input type="text" class="form-control client-nom" id="client_nom_{{ chambre.id }}" name="client_nom" required>
                                            </div>
                                            <div class="mb-3">
                                                <label for="client_email_{{ chambre.id }}" class="form-label">Email</label>
                                                <input type="email" class="form-control client-email" id="client_email_{{ chambre.id }}" name="client_email" required>
                                            </div>
                                            <div class="mb-3">
                                                <label for="client_telephone_{{ chambre.id }}" class="form-label">Téléphone</label>
                                                <input type="text" class="form-control client-telephone" id="client_telephone_{{ chambre.id }}" name="client_telephone">
                                            </div>
                                            <div class="mb-3">
                                                <label for="client_adresse_{{ chambre.id }}" class="form-label">Adresse</label>
                                                <textarea class="form-control client-adresse" id="client_adresse_{{ chambre.id }}" name="client_adresse" rows="2"></textarea>
                                            </div>

                                            <div class="mb-3">
                                                <label for="commentaire{{ chambre.id }}" class="form-label">Commentaires (optionnel)</label>
                                                <textarea class="form-control" id="commentaire{{ chambre.id }}" name="commentaire" rows="3"></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                            <button type="submit" class="btn btn-primary">Confirmer la réservation</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="alert alert-info">
                <p>Vous devez être connecté pour réserver une chambre.</p>
                <a href="{{ path('app_login', {'_target_path': path('app_reservation_search')}) }}" class="btn btn-primary">Se connecter</a>
                <a href="{{ path('app_register', {'_target_path': path('app_reservation_search')}) }}" class="btn btn-secondary">S'inscrire</a>
            </div>
        {% endif %}
    {% elseif app.request.method == 'POST' %}
        <div class="alert alert-warning mt-5">
            Aucune chambre disponible pour cette période.
        </div>
    {% endif %}

    {% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            document.querySelectorAll('.client-select').forEach(select => {

                select.addEventListener('change', function () {

                    const option = this.options[this.selectedIndex];

                    const modal = this.closest('.modal');

                    modal.querySelector('.client-nom').value =
                        option.dataset.nom ?? '';

                    modal.querySelector('.client-email').value =
                        option.dataset.email ?? '';

                    modal.querySelector('.client-telephone').value =
                        option.dataset.telephone ?? '';

                    modal.querySelector('.client-adresse').value =
                        option.dataset.adresse ?? '';

                });

            });

        });
    </script>

{% endblock %}
{% endblock %}
