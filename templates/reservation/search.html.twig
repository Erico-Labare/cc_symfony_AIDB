{% extends 'base.html.twig' %}

{% block title %}Rechercher une chambre{% endblock %}

{% block body %}

<section class="search-hero">

    <div class="search-card">

        <div class="text-center mb-4">

            <h1 class="search-title">
                Trouvez votre chambre idéale
            </h1>

            <p class="search-subtitle">
                Sélectionnez un hôtel ainsi que vos dates de séjour.
            </p>

        </div>

        {{ form_start(form) }}

        <div class="row g-3 align-items-end">

            <div class="col-lg-4">

                {{ form_label(form.hotel) }}

                {{ form_widget(form.hotel, {
                    attr:{
                        class:'form-select'
                    }
                }) }}

                {{ form_errors(form.hotel) }}

            </div>

            <div class="col-lg-3">

                {{ form_label(form.dateDebut,'Arrivée') }}

                {{ form_widget(form.dateDebut,{
                    attr:{
                        class:'form-control'
                    }
                }) }}

                {{ form_errors(form.dateDebut) }}

            </div>

            <div class="col-lg-3">

                {{ form_label(form.dateFin,'Départ') }}

                {{ form_widget(form.dateFin,{
                    attr:{
                        class:'form-control'
                    }
                }) }}

                {{ form_errors(form.dateFin) }}

            </div>

            <div class="col-lg-2 d-grid">

                <button class="btn btn-primary btn-lg">

                    <i class="bi bi-search"></i>

                    Rechercher

                </button>

            </div>

        </div>

        {{ form_end(form) }}

    </div>

</section>


{% if availableRooms is not empty %}

<section class="mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="mb-1">

                Chambres disponibles

            </h2>

            <small class="text-light">

                {{ availableRooms|length }}

                chambre(s) trouvée(s)

            </small>

        </div>

    </div>

    {% if is_granted('ROLE_USER') %}

    <div class="row g-4">

        {% for chambre in availableRooms %}

        <div class="col-xl-4 col-md-6">

            <div class="room-card">

                <div class="d-flex justify-content-between align-items-center">

                    <span class="room-type">

                        {{ chambre.type }}

                    </span>

                    <span class="room-badge">

                        Disponible

                    </span>

                </div>

                <div class="room-icon">

                    <i class="bi bi-door-open-fill"></i>

                </div>

                <h4 class="text-center">

                    Chambre {{ chambre.id }}

                </h4>

                <div class="room-details">

                    <p>

                        <i class="bi bi-building"></i>

                        {{ chambre.hotel.nom }}

                    </p>

                    <p>

                        <i class="bi bi-person-bed"></i>

                        {{ chambre.nombreLit }}

                        lit(s)

                    </p>

                    <p>

                        <i class="bi bi-layers"></i>

                        Étage {{ chambre.etage }}

                    </p>

                </div>

                <button
                    class="btn btn-primary w-100 mt-3"
                    data-bs-toggle="modal"
                    data-bs-target="#reservationModal{{ chambre.id }}">

                    Réserver cette chambre

                </button>

            </div>

        </div>

        <!-- Modal -->

        <div
            class="modal fade"
            id="reservationModal{{ chambre.id }}"
            tabindex="-1">

            <div class="modal-dialog modal-lg">

                <div class="modal-content">

                    <div class="modal-header">

                        <h5 class="modal-title">

                            Finaliser votre réservation

                        </h5>

                        <button
                            class="btn-close"
                            data-bs-dismiss="modal">
                        </button>

                    </div>

                    <form
                        method="post"
                        action="{{ path('app_reservation_create') }}">

                        <div class="modal-body">
                            
                            <input
                                type="hidden"
                                name="chambre_id"
                                value="{{ chambre.id }}">

                            <input
                                type="hidden"
                                name="dateDebut"
                                value="{{ form.dateDebut.vars.value|date('Y-m-d') }}">

                            <input
                                type="hidden"
                                name="dateFin"
                                value="{{ form.dateFin.vars.value|date('Y-m-d') }}">

                            <div class="reservation-summary">

                                <div>

                                    <strong>🏨 Hôtel</strong>

                                    <p>{{ chambre.hotel.nom }}</p>

                                </div>

                                <div>

                                    <strong>🛏 Chambre</strong>

                                    <p>

                                        {{ chambre.type }}

                                        •
                                        {{ chambre.nombreLit }}

                                        lit(s)

                                    </p>

                                </div>

                                <div>

                                    <strong>🏢 Étage</strong>

                                    <p>

                                        {{ chambre.etage }}

                                    </p>

                                </div>

                            </div>

                            <hr>

                            <div class="mb-3">

                                <label
                                    class="form-label">

                                    Voyageur

                                </label>

                                <div class="alert alert-info">

                                    Vous pouvez sélectionner un voyageur existant
                                    ou créer un nouveau client.

                                </div>

                                <select
                                    class="form-select client-select"
                                    name="client_id">

                                    <option value="">

                                        -- Nouveau client --

                                    </option>

                                    {% for client in clients %}

                                    <option

                                        value="{{ client.id }}"

                                        data-nom="{{ client.nom }}"

                                        data-email="{{ client.email }}"

                                        data-telephone="{{ client.telephone }}"

                                        data-adresse="{{ client.adresse }}">

                                        {{ client.nom }}

                                        ({{ client.email }})

                                    </option>

                                    {% endfor %}

                                </select>

                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label>Nom</label>

                                    <input
                                        class="form-control client-nom"
                                        name="client_nom"
                                        required>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label>Email</label>

                                    <input
                                        class="form-control client-email"
                                        name="client_email"
                                        type="email"
                                        required>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label>Téléphone</label>

                                    <input
                                        class="form-control client-telephone"
                                        name="client_telephone">

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label>Adresse</label>

                                    <input
                                        class="form-control client-adresse"
                                        name="client_adresse">

                                </div>

                            </div>

                            <div class="mb-3">

                                <label>

                                    Commentaire

                                </label>

                                <textarea
                                    class="form-control"
                                    rows="4"
                                    name="commentaire"></textarea>

                            </div>
                                                    </div>

                        <div class="modal-footer">

                            <button
                                type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">

                                Annuler

                            </button>

                            <button
                                type="submit"
                                class="btn btn-primary">

                                <i class="bi bi-check-circle"></i>

                                Confirmer la réservation

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

        {% endfor %}

    </div>

    {% else %}

        <div class="alert alert-info text-center p-4 mt-5">

            <h4>

                Connectez-vous pour réserver une chambre.

            </h4>

            <div class="mt-3">

                <a
                    href="{{ path('app_login', {
                        '_target_path': path('app_reservation_search')
                    }) }}"
                    class="btn btn-primary me-2">

                    Connexion

                </a>

                <a
                    href="{{ path('app_register', {
                        '_target_path': path('app_reservation_search')
                    }) }}"
                    class="btn btn-outline-light">

                    Inscription

                </a>

            </div>

        </div>

    {% endif %}

</section>

{% elseif app.request.method == 'POST' %}

    <div class="alert alert-warning text-center mt-5 p-4">

        <h4>

            Aucune chambre disponible

        </h4>

        <p class="mb-0">

            Essayez une autre période ou un autre hôtel.

        </p>

    </div>

{% endif %}

{% endblock %}

{% block javascripts %}

{{ parent() }}

<script>

document.addEventListener('DOMContentLoaded', () => {

    document.querySelectorAll('.client-select').forEach(select => {

        select.addEventListener('change', function () {

            const option = this.options[this.selectedIndex];

            const modal = this.closest('.modal');

            modal.querySelector('.client-nom').value =
                option.dataset.nom ?? '';

            modal.querySelector('.client-email').value =
                option.dataset.email ?? '';

            modal.querySelector('.client-telephone').value =
                option.dataset.telephone ?? '';

            modal.querySelector('.client-adresse').value =
                option.dataset.adresse ?? '';

        });

    });

});

</script>

{% endblock %}