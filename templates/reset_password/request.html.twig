{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}

<section class="profile-page">

    <div class="text-center mb-5">

        <div class="mb-3">
            <i class="bi bi-envelope-lock-fill fs-1 text-warning"></i>
        </div>

        <h1 class="page-title">
            Mot de passe oublié
        </h1>

        <p class="page-subtitle">
            Recevez un lien sécurisé pour réinitialiser votre mot de passe.
        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-5">

            <div class="reservation-card">

                {% for flash_error in app.flashes('reset_password_error') %}
                    <div class="alert alert-danger">
                        {{ flash_error }}
                    </div>
                {% endfor %}

                <div class="reservation-summary mb-4">

                    <div class="summary-item">

                        <i class="bi bi-info-circle-fill"></i>

                        <span>

                            Saisissez votre adresse email. Si un compte existe, vous recevrez un lien de réinitialisation.

                        </span>

                    </div>

                </div>

                {{ form_start(requestForm) }}

                    <div class="mb-4">

                        {{ form_label(requestForm.email, 'Adresse email', {
                            label_attr: {
                                class: 'form-label fw-semibold'
                            }
                        }) }}

                        {{ form_widget(requestForm.email, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'nom@exemple.fr'
                            }
                        }) }}

                        {{ form_errors(requestForm.email) }}

                    </div>

                    <button class="btn btn-primary w-100">

                        <i class="bi bi-send"></i>

                        Envoyer le lien

                    </button>

                {{ form_end(requestForm) }}

            </div>

        </div>

    </div>

</section>

{% endblock %}