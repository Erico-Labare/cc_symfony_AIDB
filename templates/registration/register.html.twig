{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}

<section class="profile-page">

    <div class="text-center mb-5">

        <div class="mb-3">
            <i class="bi bi-building-fill fs-1 text-warning"></i>
        </div>

        <h1 class="page-title">
            Créer un compte
        </h1>

        <p class="page-subtitle">
            Rejoignez Hotel Booking en quelques secondes.
        </p>

        <p class="text-white-50">
            Créez votre compte pour réserver des chambres pour vous ou vos proches et gérer facilement vos séjours.
        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="reservation-card">

                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="alert alert-danger">
                        {{ flash_error }}
                    </div>
                {% endfor %}

                {{ form_start(registrationForm) }}

                    <div class="mb-4">

                        {{ form_label(registrationForm.email, 'Adresse email', {
                            label_attr: {
                                class: 'form-label fw-semibold'
                            }
                        }) }}

                        {{ form_widget(registrationForm.email, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Votre adresse email'
                            }
                        }) }}

                        {{ form_errors(registrationForm.email) }}

                    </div>

                    <div class="mb-4">

                        {{ form_label(registrationForm.plainPassword, 'Mot de passe', {
                            label_attr: {
                                class: 'form-label fw-semibold'
                            }
                        }) }}

                        {{ form_widget(registrationForm.plainPassword, {
                            attr: {
                                class: 'form-control',
                                placeholder: 'Choisissez un mot de passe'
                            }
                        }) }}

                        {{ form_errors(registrationForm.plainPassword) }}

                    </div>

                    <div class="form-check mb-4">

                        {{ form_widget(registrationForm.agreeTerms, {
                            attr: {
                                class: 'form-check-input'
                            }
                        }) }}

                        {{ form_label(registrationForm.agreeTerms, null, {
                            label_attr: {
                                class: 'form-check-label'
                            }
                        }) }}

                    </div>

                    {{ form_errors(registrationForm.agreeTerms) }}

                    <button
                        type="submit"
                        class="btn btn-primary w-100">

                        <i class="bi bi-person-plus"></i>

                        Créer mon compte

                    </button>

                {{ form_end(registrationForm) }}

                <hr class="my-4">

                <div class="text-center">

                    Déjà inscrit ?

                    <a
                        href="{{ path('app_login') }}"
                        class="text-decoration-none">

                        Se connecter

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

{% endblock %}