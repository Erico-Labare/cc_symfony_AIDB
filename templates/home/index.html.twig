{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<section class="hero-section">

    <div class="hero-content">

        <span class="hero-badge">
            HOTEL BOOKING
        </span>

        <h1 class="hero-title">
            Votre séjour commence ici.
        </h1>

        <p class="hero-subtitle">
            Réservez une chambre parmi nos hôtels partenaires pour vous ou vos proches.
            Gérez facilement vos réservations, vos voyageurs et vos commentaires depuis une interface moderne.
        </p>

        <div class="hero-buttons">

            <a href="{{ path('app_reservation_search') }}"
               class="btn btn-primary btn-lg">

                <i class="bi bi-search"></i>

                Réserver une chambre

            </a>

            {% if app.user %}

                <a href="{{ path('app_reservation_my_reservations') }}"
                   class="btn btn-outline-light btn-lg">

                    <i class="bi bi-calendar-check"></i>

                    Mes réservations

                </a>

            {% endif %}

        </div>

    </div>

</section>


<section class="stats-section">

    <div class="row g-4">

        <div class="col-md-6 col-xl-3">

            <div class="stat-card">

                <div class="stat-icon">
                    <i class="bi bi-building"></i>
                </div>

                <h2 class="section-title">{{ hotelCount }}</h2>

                <p>Hôtels partenaires</p>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="stat-card">

                <div class="stat-icon">
                    <i class="bi bi-door-open"></i>
                </div>

                <h2 class="section-title">{{ roomCount }}</h2>

                <p>Chambres</p>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="stat-card">

                <div class="stat-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>

                <h2 class="section-title">{{ reservationCount }}</h2>

                <p>Réservations</p>

            </div>

        </div>

        <div class="col-md-6 col-xl-3">

            <div class="stat-card">

                <div class="stat-icon">
                    <i class="bi bi-people"></i>
                </div>

                <h2 class="section-title">{{ clientCount }}</h2>

                <p>Clients</p>

            </div>

        </div>

    </div>

</section>


<section class="features-section">

    <div class="card">

        <div class="card-body">

            <h2 class="section-title">
                Pourquoi choisir Hotel Booking ?
            </h2>

            <div class="row mt-4">

                <div class="col-md-6">

                    <div class="feature-item">

                        <i class="bi bi-check-circle-fill"></i>

                        Recherche rapide des chambres disponibles

                    </div>

                    <div class="feature-item">

                        <i class="bi bi-check-circle-fill"></i>

                        Réservation pour vous ou vos proches

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="feature-item">

                        <i class="bi bi-check-circle-fill"></i>

                        Modification des commentaires

                    </div>

                    <div class="feature-item">

                        <i class="bi bi-check-circle-fill"></i>

                        Annulation sécurisée des réservations

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>


<section class="cta-section">

    <div class="card">

        <div class="card-body text-center">

            <h2 class="section-title">
                Prêt à réserver ?
            </h2>

            <p>
                Trouvez dès maintenant la chambre idéale parmi nos établissements partenaires.
            </p>

            <a href="{{ path('app_reservation_search') }}"
               class="btn btn-primary btn-lg">

                Commencer une réservation

            </a>

        </div>

    </div>

</section>

{% endblock %}