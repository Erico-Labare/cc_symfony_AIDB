{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<div class="p-5 bg-light rounded">

    <h1>Bienvenue sur la plateforme de réservation</h1>

    <p class="lead">
        Recherchez et réservez des chambres d'hôtel en quelques clics.
    </p>



    <div class="mt-4 d-flex align-items-center"> {# Added d-flex and align-items-center for horizontal alignment #}
        <a href="{{ path('app_reservation_search') }}" class="btn btn-success btn-lg me-2"> {# Added me-2 for margin-end #}
            Chercher une chambre
        </a>
        {% if is_granted('ROLE_ADMIN') %}
            <a class="btn btn-warning btn-lg" href="{{ path('app_admin') }}">
                Gestion de l'administration
            </a>
        {% endif %}
    </div>

    {% if app.user %}

        <div class="alert alert-success mt-4">
            <p><strong>Utilisateur connecté :</strong></p>

            <p>Email : {{ app.user.userIdentifier }}</p>

            <p>
                Rôles :
                {% for role in app.user.roles %}
                    <span class="badge bg-primary">{{ role }}</span>
                {% endfor %}
            </p>

            <div class="mt-3">
                <a href="{{ path('app_reservation_my_reservations') }}" class="btn btn-info">
                    Voir mes réservations
                </a>
            </div>
        </div>
    {% else %}
        <div class="mt-4">
            <a href="{{ path('app_register') }}" class="btn btn-primary">
                Créer un compte
            </a>

            <a href="{{ path('app_login') }}" class="btn btn-outline-dark">
                Se connecter
            </a>
        </div>
    {% endif %}

</div>

{% endblock %}
