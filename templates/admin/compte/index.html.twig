{% extends 'base.html.twig' %}

{% block title %}Gestion des Comptes{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Gestion des comptes
        </h1>

        <p class="page-subtitle">
            Consultez, recherchez et gérez les comptes utilisateurs.
        </p>

    </div>

    <div class="admin-toolbar">

        <div class="row g-3 align-items-end">

            <div class="col-lg-8">

                <label class="form-label">

                    Rechercher un compte

                </label>

                <form method="GET" action="{{ path('app_admin_compte_index') }}">

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        value="{{ search }}"
                        placeholder="Email ou rôle">

                </form>

            </div>

            <div class="col-lg-2 d-grid">

                <button
                    formmethod="GET"
                    formaction="{{ path('app_admin_compte_index') }}"
                    class="btn btn-primary">

                    <i class="bi bi-search me-2"></i>

                    Rechercher

                </button>

            </div>

            <div class="col-lg-2 d-grid">

                <a
                    href="{{ path('app_admin_compte_new') }}"
                    class="btn btn-success">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nouveau

                </a>

            </div>

        </div>

    </div>

    <table class="table admin-table align-middle">

        <thead>

            <tr>

                <th style="width:90px;">#</th>

                <th>Compte</th>

                <th>Rôle</th>

                <th>Statut</th>

                <th class="text-center" style="width:170px;">Actions</th>

            </tr>

        </thead>

        <tbody>

        {% for compte in comptes %}

            <tr>

                <td>

                    <span class="badge bg-primary">

                        #{{ compte.id }}

                    </span>

                </td>

                <td>

                    <strong>

                        {{ compte.email }}

                    </strong>

                </td>

                <td>

                    {% if 'ROLE_ADMIN' in compte.roles %}

                        <span class="badge bg-warning text-dark">

                            Administrateur

                        </span>

                    {% else %}

                        <span class="badge bg-info">

                            Utilisateur

                        </span>

                    {% endif %}

                </td>

                <td>

                    {% if compte.isVerified %}

                        <span class="badge bg-success">

                            Vérifié

                        </span>

                    {% else %}

                        <span class="badge bg-danger">

                            Non vérifié

                        </span>

                    {% endif %}

                </td>

                <td class="text-center">

                    <div class="d-flex justify-content-center gap-2">

                        <a
                            href="{{ path('app_admin_compte_show',{id:compte.id}) }}"
                            class="btn btn-outline-primary btn-sm">

                            <i class="bi bi-eye"></i>

                        </a>

                        <a
                            href="{{ path('app_admin_compte_edit',{id:compte.id}) }}"
                            class="btn btn-outline-warning btn-sm">

                            <i class="bi bi-pencil-square"></i>

                        </a>

                        <button
                            type="button"
                            class="btn btn-outline-danger btn-sm delete-button"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"

                            data-action="{{ path('app_admin_compte_delete',{id:compte.id}) }}"

                            data-token="{{ csrf_token('delete' ~ compte.id) }}"

                            data-message="Êtes-vous sûr de vouloir supprimer le compte « {{ compte.email }} » ?">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>

                </td>

            </tr>

        {% else %}

            <tr>

                <td colspan="5" class="text-center py-5">

                    <i class="bi bi-person-lock fs-1 text-secondary"></i>

                    <br><br>

                    Aucun compte trouvé.

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

    <nav aria-label="Pagination">

        <ul class="pagination justify-content-center">

            <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_compte_index',{
                        page:page-1,
                        search:search
                   }) }}">

                    Précédent

                </a>

            </li>

            {% for i in 1..maxPages %}

                <li class="page-item {{ page==i ? 'active' : '' }}">

                    <a class="page-link"
                       href="{{ path('app_admin_compte_index',{
                            page:i,
                            search:search
                       }) }}">

                        {{ i }}

                    </a>

                </li>

            {% endfor %}

            <li class="page-item {{ page>=maxPages ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_compte_index',{
                        page:page+1,
                        search:search
                   }) }}">

                    Suivant

                </a>

            </li>

        </ul>

    </nav>

    <div class="mt-4">

        <a
            href="{{ path('app_admin') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Tableau de bord

        </a>

    </div>

</div>

{% endblock %}