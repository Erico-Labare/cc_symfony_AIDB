<form method="post" action="{{ path('app_admin_compte_delete', {'id': compte.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ compte.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
