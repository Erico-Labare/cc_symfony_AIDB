{% extends 'base.html.twig' %}

{% block title %}Compte{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Détails du Compte</h1>

        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ compte.id }}</td>
                </tr>
                <tr>
                    <th>Role</th>
                    <td>{{ compte.role }}</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>{{ compte.email }}</td>
                </tr>
                <tr>
                    <th>Password</th>
                    <td>{{ compte.password }}</td>
                </tr>
                <tr>
                    <th>IsVerified</th>
                    <td>{{ compte.isVerified ? 'Oui' : 'Non' }}</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <div>
                <a href="{{ path('app_admin_compte_index') }}" class="btn btn-secondary">Retour à la liste</a>
                <a href="{{ path('app_admin_compte_edit', {'id': compte.id}) }}" class="btn btn-warning">Modifier</a>
            </div>
            {{ include('admin/compte/_delete_form.html.twig') }}
        </div>
        <div class="mt-3">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
