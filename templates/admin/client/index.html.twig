{% extends 'base.html.twig' %}

{% block title %}Gestion des Clients{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Gestion des clients
        </h1>

        <p class="page-subtitle">
            Consultez, recherchez et gérez les clients enregistrés.
        </p>

    </div>

    <div class="admin-toolbar">

        <div class="row g-3 align-items-end">

            <div class="col-lg-8">

                <label class="form-label">
                    Rechercher un client
                </label>

                <form method="GET" action="{{ path('app_admin_client_index') }}">

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        value="{{ search }}"
                        placeholder="Nom ou adresse email">

                </form>

            </div>

            <div class="col-lg-2 d-grid">

                <button
                    formmethod="GET"
                    formaction="{{ path('app_admin_client_index') }}"
                    class="btn btn-primary">

                    <i class="bi bi-search me-2"></i>

                    Rechercher

                </button>

            </div>

            <div class="col-lg-2 d-grid">

                <a
                    href="{{ path('app_admin_client_new') }}"
                    class="btn btn-success">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nouveau

                </a>

            </div>

        </div>

    </div>

    <table class="table admin-table align-middle">

        <thead>

            <tr>

                <th style="width:90px;">#</th>

                <th>Client</th>

                <th>Contact</th>

                <th>Adresse</th>

                <th class="text-center" style="width:170px;">Actions</th>

            </tr>

        </thead>

        <tbody>

        {% for client in clients %}

            <tr>

                <td>

                    <span class="badge bg-primary">

                        #{{ client.id }}

                    </span>

                </td>

                <td>

                    <strong>

                        {{ client.nom }}

                    </strong>

                </td>

                <td>

                    {{ client.email }}

                    <br>

                    <small class="text-muted">

                        {{ client.telephone ?: 'Non renseigné' }}

                    </small>

                </td>

                <td>

                    {{ client.adresse }}

                </td>

                <td class="text-center">

                    <div class="d-flex justify-content-center gap-2">

                        <a
                            href="{{ path('app_admin_client_show',{id:client.id}) }}"
                            class="btn btn-outline-primary btn-sm">

                            <i class="bi bi-eye"></i>

                        </a>

                        <a
                            href="{{ path('app_admin_client_edit',{id:client.id}) }}"
                            class="btn btn-outline-warning btn-sm">

                            <i class="bi bi-pencil-square"></i>

                        </a>

                        <form
                            method="post"
                            action="{{ path('app_admin_client_delete',{id:client.id}) }}"
                            onsubmit="return confirm('Supprimer ce client ?');">

                            <input
                                type="hidden"
                                name="_token"
                                value="{{ csrf_token('delete' ~ client.id) }}">

                            <button class="btn btn-outline-danger btn-sm">

                                <i class="bi bi-trash"></i>

                            </button>

                        </form>

                    </div>

                </td>

            </tr>

        {% else %}

            <tr>

                <td colspan="5" class="text-center py-5">

                    <i class="bi bi-person-x fs-1 text-secondary"></i>

                    <br><br>

                    Aucun client trouvé.

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

    <nav aria-label="Pagination">

        <ul class="pagination justify-content-center">

            <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_client_index',{
                        page:page-1,
                        search:search
                   }) }}">

                    Précédent

                </a>

            </li>

            {% for i in 1..maxPages %}

                <li class="page-item {{ page==i ? 'active' : '' }}">

                    <a class="page-link"
                       href="{{ path('app_admin_client_index',{
                            page:i,
                            search:search
                       }) }}">

                        {{ i }}

                    </a>

                </li>

            {% endfor %}

            <li class="page-item {{ page>=maxPages ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_client_index',{
                        page:page+1,
                        search:search
                   }) }}">

                    Suivant

                </a>

            </li>

        </ul>

    </nav>

    <div class="mt-4">

        <a
            href="{{ path('app_admin') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Tableau de bord

        </a>

    </div>

</div>

{% endblock %}