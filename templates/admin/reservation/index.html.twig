{% extends 'base.html.twig' %}

{% block title %}Gestion des Réservations{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Gestion des Réservations</h1>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="{{ path('app_admin_reservation_new') }}" class="btn btn-primary">Créer une nouvelle réservation</a>
            <div class="d-flex">
                {# Nouvelle barre de recherche par ID de réservation #}
                <form method="GET" action="{{ path('app_admin_reservation_index') }}" class="d-flex me-2">
                    <input type="text" name="reservation_id" class="form-control me-2" placeholder="Rechercher par ID Réservation" value="{{ app.request.query.get('reservation_id') }}" style="width: 250px;">
                    <button type="submit" class="btn btn-outline-secondary">Rechercher ID</button>
                </form>
                {# Barre de recherche existante modifiée #}
                <form method="GET" action="{{ path('app_admin_reservation_index') }}" class="d-flex">
                    <input type="text" name="search" class="form-control me-2" placeholder="Rechercher (email client, ID chambre)" value="{{ search }}" style="width: 350px;">
                    <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
                </form>
            </div>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Date de début</th>
                    <th>Date de fin</th>
                    <th>Commentaire</th>
                    <th>Compte (Email)</th>
                    <th>Client (Email)</th>
                    <th>Chambre (ID)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                    <tr>
                        <td>{{ reservation.id }}</td>
                        <td>{{ reservation.dateDebut ? reservation.dateDebut|date('Y-m-d') : '' }}</td>
                        <td>{{ reservation.dateFin ? reservation.dateFin|date('Y-m-d') : '' }}</td>
                        <td>{{ reservation.commentaire }}</td>
                        <td>{{ reservation.compte ? reservation.compte.email : 'N/A' }}</td>
                        <td>{{ reservation.client ? reservation.client.email : 'N/A' }}</td>
                        <td>{{ reservation.chambre ? reservation.chambre.id : 'N/A' }}</td>
                        <td>
                            <a href="{{ path('app_admin_reservation_show', { 'id': reservation.id }) }}" class="btn btn-info btn-sm">Voir</a>
                            <a href="{{ path('app_admin_reservation_edit', { 'id': reservation.id }) }}" class="btn btn-warning btn-sm">Modifier</a>
                            <form method="post" action="{{ path('app_admin_reservation_delete', { 'id': reservation.id }) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette réservation ?');" style="display: inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                <button class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8">Aucune réservation trouvée</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ (page <= 1) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': page - 1, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">Précédent</a>
                </li>
                {% for i in 1..maxPages %}
                    <li class="page-item {{ (page == i) ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': i, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ (page >= maxPages) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': page + 1, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">Suivant</a>
                </li>
            </ul>
        </nav>

        <div class="mt-4">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
