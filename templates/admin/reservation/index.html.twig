{% extends 'base.html.twig' %}

{% block title %}Gestion des Réservations{% endblock %}

{% block body %}
    <div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Gestion des réservations
        </h1>

        <p class="page-subtitle">
            Consultez, recherchez et gérez toutes les réservations de votre établissement.
        </p>

    </div>

    <div class="admin-toolbar">

        <div class="row g-3 align-items-end">

            <div class="col-lg-3">

                <label class="form-label">
                    ID réservation
                </label>

                <form method="GET" action="{{ path('app_admin_reservation_index') }}">

                    <input
                        type="text"
                        name="reservation_id"
                        class="form-control"
                        value="{{ app.request.query.get('reservation_id') }}"
                        placeholder="Ex : 15">

                </form>

            </div>

            <div class="col-lg-5">

                <label class="form-label">
                    Client ou chambre
                </label>

                <form method="GET" action="{{ path('app_admin_reservation_index') }}">

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        value="{{ search }}"
                        placeholder="Email client ou ID chambre">

                </form>

            </div>

            <div class="col-lg-2 d-grid">

                <button
                    formmethod="GET"
                    formaction="{{ path('app_admin_reservation_index') }}"
                    class="btn btn-primary">

                    <i class="bi bi-search me-2"></i>

                    Rechercher

                </button>

            </div>

            <div class="col-lg-2 d-grid">

                <a
                    href="{{ path('app_admin_reservation_new') }}"
                    class="btn btn-success">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nouvelle

                </a>

            </div>

        </div>

    </div>

        <table class="table admin-table align-middle">

            <thead>

                <tr>

                    <th style="width:90px;">#</th>

                    <th>Séjour</th>

                    <th>Client</th>

                    <th>Chambre</th>

                    <th>Commentaire</th>

                    <th class="text-center" style="width:170px;">Actions</th>

                </tr>

            </thead>

            <tbody>

            {% for reservation in reservations %}

                <tr>

                    <td>

                        <span class="badge bg-primary fs-6">

                            #{{ reservation.id }}

                        </span>

                    </td>

                    <td>

                        <strong>

                            {{ reservation.dateDebut|date('d/m/Y') }}

                        </strong>

                        <br>

                        <small class="text-muted">

                            →

                            {{ reservation.dateFin|date('d/m/Y') }}

                        </small>

                    </td>

                    <td>

                        <strong>

                            {{ reservation.client.nom }}

                        </strong>

                        <br>

                        <small class="text-muted">

                            {{ reservation.client.email }}

                        </small>

                    </td>

                    <td>

                        <strong>

                            Chambre {{ reservation.chambre.id }}

                        </strong>

                        <br>

                        <small class="text-muted">

                            {{ reservation.chambre.hotel.nom }}

                        </small>

                    </td>

                    <td>

                        {{ reservation.commentaire ? reservation.commentaire|slice(0, 35) ~ (reservation.commentaire|length > 35 ? '...' : '') : '—' }}

                    </td>

                    <td class="text-center">

                        <div class="d-flex justify-content-center gap-2">

                            <a
                                href="{{ path('app_admin_reservation_show', {'id': reservation.id}) }}"
                                class="btn btn-outline-primary btn-sm"
                                title="Voir">

                                <i class="bi bi-eye"></i>

                            </a>

                            <a
                                href="{{ path('app_admin_reservation_edit', {'id': reservation.id}) }}"
                                class="btn btn-outline-warning btn-sm"
                                title="Modifier">

                                <i class="bi bi-pencil-square"></i>

                            </a>

                            <form
                                method="post"
                                action="{{ path('app_admin_reservation_delete', {'id': reservation.id}) }}"
                                onsubmit="return confirm('Supprimer cette réservation ?');">

                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('delete' ~ reservation.id) }}">

                                <button
                                    class="btn btn-outline-danger btn-sm"
                                    title="Supprimer">

                                    <i class="bi bi-trash"></i>

                                </button>

                            </form>

                        </div>

                    </td>

                </tr>

            {% else %}

                <tr>

                    <td colspan="6" class="text-center py-5">

                        <i class="bi bi-calendar-x fs-1 text-secondary"></i>

                        <br><br>

                        Aucune réservation trouvée.

                    </td>

                </tr>

            {% endfor %}

            </tbody>

        </table>

        {# Pagination #}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ (page <= 1) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': page - 1, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">Précédent</a>
                </li>
                {% for i in 1..maxPages %}
                    <li class="page-item {{ (page == i) ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': i, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ (page >= maxPages) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_reservation_index', {'page': page + 1, 'search': search, 'reservation_id': app.request.query.get('reservation_id')}) }}">Suivant</a>
                </li>
            </ul>
        </nav>

        <div class="mt-4">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
