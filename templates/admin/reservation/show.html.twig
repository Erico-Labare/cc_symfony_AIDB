{% extends 'base.html.twig' %}

{% block title %}Réservation #{{ reservation.id }}{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">

            Réservation #{{ reservation.id }}

        </h1>

        <p class="page-subtitle">

            Consultez toutes les informations concernant cette réservation.

        </p>

    </div>

    <div class="row g-4">

        <div class="col-lg-6">

            <div class="reservation-card">

                <h4 class="mb-4">

                    <i class="bi bi-calendar-check me-2"></i>

                    Séjour

                </h4>

                <p>

                    <strong>Arrivée</strong><br>

                    {{ reservation.dateDebut|date('d/m/Y') }}

                </p>

                <p>

                    <strong>Départ</strong><br>

                    {{ reservation.dateFin|date('d/m/Y') }}

                </p>

                <p>

                    <strong>Compte associé</strong><br>

                    {{ reservation.compte ? reservation.compte.email : 'Aucun compte' }}

                </p>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="reservation-card">

                <h4 class="mb-4">

                    <i class="bi bi-person-fill me-2"></i>

                    Client

                </h4>

                <p>

                    <strong>Nom</strong><br>

                    {{ reservation.client.nom }}

                </p>

                <p>

                    <strong>Email</strong><br>

                    {{ reservation.client.email }}

                </p>

                <p>

                    <strong>Téléphone</strong><br>

                    {{ reservation.client.telephone ?: 'Non renseigné' }}

                </p>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="reservation-card">

                <h4 class="mb-4">

                    <i class="bi bi-building me-2"></i>

                    Chambre

                </h4>

                <p>

                    <strong>Hôtel</strong><br>

                    {{ reservation.chambre.hotel.nom }}

                </p>

                <p>

                    <strong>Type</strong><br>

                    {{ reservation.chambre.type }}

                </p>

                <p>

                    <strong>Étage</strong><br>

                    {{ reservation.chambre.etage }}

                </p>

                <p>

                    <strong>Nombre de lits</strong><br>

                    {{ reservation.chambre.nombreLit }}

                </p>

            </div>

        </div>

        <div class="col-lg-6">

            <div class="reservation-card">

                <h4 class="mb-4">

                    <i class="bi bi-chat-left-text me-2"></i>

                    Commentaire

                </h4>

                {% if reservation.commentaire %}

                    <div class="comment-box">

                        {{ reservation.commentaire }}

                    </div>

                {% else %}

                    <div class="comment-box text-muted">

                        Aucun commentaire.

                    </div>

                {% endif %}

            </div>

        </div>

    </div>

    <div class="reservation-actions mt-5">

        <a
            href="{{ path('app_admin_reservation_index') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Retour

        </a>

        <div class="d-flex gap-2">

            <a
                href="{{ path('app_admin_reservation_edit', {'id': reservation.id}) }}"
                class="btn btn-warning">

                <i class="bi bi-pencil-square me-2"></i>

                Modifier

            </a>

            <button
                type="button"
                class="btn btn-danger delete-button"

                data-bs-toggle="modal"
                data-bs-target="#deleteModal"

                data-action="{{ path('app_admin_reservation_delete',{id:reservation.id}) }}"

                data-token="{{ csrf_token('delete' ~ reservation.id) }}"

                data-message="Êtes-vous sûr de vouloir supprimer la réservation n°{{ reservation.id }} ?">

                <i class="bi bi-trash me-2"></i>

                Supprimer

            </button>
        </div>

    </div>

</div>

{% endblock %}