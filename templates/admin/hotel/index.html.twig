{% extends 'base.html.twig' %}

{% block title %}Gestion des Hôtels{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Gestion des Hôtels</h1>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="{{ path('app_admin_hotel_new') }}" class="btn btn-primary">Créer un nouvel hôtel</a>
            <form method="GET" action="{{ path('app_admin_hotel_index') }}" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Rechercher (nom/catégorie)" value="{{ search }}" style="width: 250px;"> {# Added style attribute #}
                <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
            </form>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Adresse</th>
                    <th>Catégorie</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for hotel in hotels %}
                <tr>
                    <td>{{ hotel.id }}</td>
                    <td>{{ hotel.nom }}</td>
                    <td>{{ hotel.adresse }}</td>
                    <td>{{ hotel.categorie }}</td>
                    <td>
                        <a href="{{ path('app_admin_hotel_show', {'id': hotel.id}) }}" class="btn btn-info btn-sm">Voir</a>
                        <a href="{{ path('app_admin_hotel_edit', {'id': hotel.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                        <form method="post" action="{{ path('app_admin_hotel_delete', {'id': hotel.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet hôtel ?');" style="display: inline-block;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ hotel.id) }}">
                            <button class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Aucun hôtel trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ (page <= 1) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_hotel_index', {'page': page - 1, 'search': search}) }}">Précédent</a>
                </li>
                {% for i in 1..maxPages %}
                    <li class="page-item {{ (page == i) ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_admin_hotel_index', {'page': i, 'search': search}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ (page >= maxPages) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_hotel_index', {'page': page + 1, 'search': search}) }}">Suivant</a>
                </li>
            </ul>
        </nav>

        <div class="mt-4">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
