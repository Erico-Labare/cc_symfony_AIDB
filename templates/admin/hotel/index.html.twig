{% extends 'base.html.twig' %}

{% block title %}Gestion des Hôtels{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Gestion des hôtels
        </h1>

        <p class="page-subtitle">
            Consultez, recherchez et gérez les hôtels enregistrés.
        </p>

    </div>

    <div class="admin-toolbar">

        <form method="GET" action="{{ path('app_admin_hotel_index') }}">

            <div class="row g-3 align-items-end">

                <div class="col-lg-8">

                    <label class="form-label">
                        Rechercher un hôtel
                    </label>

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        value="{{ search }}"
                        placeholder="Nom ou catégorie">

                </div>

                <div class="col-lg-2 d-grid">

                    <button
                        type="submit"
                        class="btn btn-primary">

                        <i class="bi bi-search me-2"></i>

                        Rechercher

                    </button>

                </div>

                <div class="col-lg-2 d-grid">

                    <a
                        href="{{ path('app_admin_hotel_new') }}"
                        class="btn btn-success">

                        <i class="bi bi-plus-circle me-2"></i>

                        Nouveau

                    </a>

                </div>

            </div>

        </form>

    </div>

    <table class="table admin-table align-middle">

        <thead>

            <tr>

                <th style="width:90px;">#</th>

                <th>Hôtel</th>

                <th>Catégorie</th>

                <th>Adresse</th>

                <th class="text-center" style="width:170px;">Actions</th>

            </tr>

        </thead>

        <tbody>

        {% for hotel in hotels %}

            <tr>

                <td>

                    <span class="badge bg-primary fs-6">

                        #{{ hotel.id }}

                    </span>

                </td>

                <td>

                    <strong>

                        {{ hotel.nom }}

                    </strong>

                </td>

                <td>

                    <span class="badge bg-warning text-dark">

                        {{ hotel.categorie }} ★

                    </span>

                </td>

                <td>

                    {{ hotel.adresse }}

                </td>

                <td class="text-center">

                    <div class="d-flex justify-content-center gap-2">

                        <a
                            href="{{ path('app_admin_hotel_show', {'id': hotel.id}) }}"
                            class="btn btn-outline-primary btn-sm"
                            title="Voir">

                            <i class="bi bi-eye"></i>

                        </a>

                        <a
                            href="{{ path('app_admin_hotel_edit', {'id': hotel.id}) }}"
                            class="btn btn-outline-warning btn-sm"
                            title="Modifier">

                            <i class="bi bi-pencil-square"></i>

                        </a>

                        <button
                            type="button"
                            class="btn btn-outline-danger btn-sm delete-button"

                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"

                            data-action="{{ path('app_admin_hotel_delete',{id:hotel.id}) }}"

                            data-token="{{ csrf_token('delete' ~ hotel.id) }}"

                            data-message="Êtes-vous sûr de vouloir supprimer l'hôtel « {{ hotel.nom }} » ?">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>

                </td>

            </tr>

        {% else %}

            <tr>

                <td colspan="5" class="text-center py-5">

                    <i class="bi bi-building fs-1 text-secondary"></i>

                    <br><br>

                    Aucun hôtel trouvé.

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

    <nav aria-label="Pagination">

        <ul class="pagination justify-content-center">

            <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_hotel_index',{
                        page:page-1,
                        search:search
                   }) }}">

                    Précédent

                </a>

            </li>

            {% for i in 1..maxPages %}

                <li class="page-item {{ page==i ? 'active' : '' }}">

                    <a class="page-link"
                       href="{{ path('app_admin_hotel_index',{
                            page:i,
                            search:search
                       }) }}">

                        {{ i }}

                    </a>

                </li>

            {% endfor %}

            <li class="page-item {{ page >= maxPages ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_hotel_index',{
                        page:page+1,
                        search:search
                   }) }}">

                    Suivant

                </a>

            </li>

        </ul>

    </nav>

    <div class="mt-4">

        <a
            href="{{ path('app_admin') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Tableau de bord

        </a>

    </div>

</div>

{% endblock %}