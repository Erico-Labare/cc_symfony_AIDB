{% extends 'base.html.twig' %}

{% block title %}Hôtel {{ hotel.nom }}{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">

            {{ hotel.nom }}

        </h1>

        <p class="page-subtitle">

            Consultez les informations de cet hôtel.

        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="reservation-card">

                <h4 class="mb-4">

                    <i class="bi bi-building me-2"></i>

                    Informations générales

                </h4>

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <strong>Identifiant</strong>

                        <p class="mt-2">

                            <span class="badge bg-primary">

                                #{{ hotel.id }}

                            </span>

                        </p>

                    </div>

                    <div class="col-md-6 mb-4">

                        <strong>Catégorie</strong>

                        <p class="mt-2">

                            <span class="badge bg-warning text-dark">

                                {{ hotel.categorie }} ★

                            </span>

                        </p>

                    </div>

                </div>

                <div class="mb-4">

                    <strong>Nom de l'hôtel</strong>

                    <p class="mt-2">

                        {{ hotel.nom }}

                    </p>

                </div>

                <div class="mb-4">

                    <strong>Adresse</strong>

                    <p class="mt-2">

                        {{ hotel.adresse }}

                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="reservation-actions mt-5">

        <a
            href="{{ path('app_admin_hotel_index') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Retour

        </a>

        <div class="d-flex gap-2">

            <a
                href="{{ path('app_admin_hotel_edit', {'id': hotel.id}) }}"
                class="btn btn-warning">

                <i class="bi bi-pencil-square me-2"></i>

                Modifier

            </a>

            {{ include('admin/hotel/_delete_form.html.twig') }}

        </div>

    </div>

</div>

{% endblock %}