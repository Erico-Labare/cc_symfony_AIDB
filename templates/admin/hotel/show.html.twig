{% extends 'base.html.twig' %}

{% block title %}Hotel{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Détails de l'Hôtel</h1>

        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ hotel.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ hotel.nom }}</td>
                </tr>
                <tr>
                    <th>Adresse</th>
                    <td>{{ hotel.adresse }}</td>
                </tr>
                <tr>
                    <th>Categorie</th>
                    <td>{{ hotel.categorie }}</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <div>
                <a href="{{ path('app_admin_hotel_index') }}" class="btn btn-secondary">Retour à la liste</a>
                <a href="{{ path('app_admin_hotel_edit', {'id': hotel.id}) }}" class="btn btn-warning">Modifier</a>
            </div>
            {{ include('admin/hotel/_delete_form.html.twig') }}
        </div>
        <div class="mt-3">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
