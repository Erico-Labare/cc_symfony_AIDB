<form method="post" action="{{ path('app_admin_hotel_delete', {'id': hotel.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');" style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ hotel.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
