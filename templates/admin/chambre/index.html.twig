{% extends 'base.html.twig' %}

{% block title %}Gestion des Chambres{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Gestion des Chambres</h1>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="{{ path('app_admin_chambre_new') }}" class="btn btn-primary">Créer une nouvelle chambre</a>
            <form method="GET" action="{{ path('app_admin_chambre_index') }}" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Rechercher (type/étage)" value="{{ search }}">
                <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
            </form>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Etage</th>
                    <th>Type</th>
                    <th>NombreLit</th>
                    <th>Hôtel</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for chambre in chambres %}
                <tr>
                    <td>{{ chambre.id }}</td>
                    <td>{{ chambre.etage }}</td>
                    <td>{{ chambre.type }}</td>
                    <td>{{ chambre.nombreLit }}</td>
                    <td>{{ chambre.hotel.nom}}</td>
                    <td>
                        <a href="{{ path('app_admin_chambre_show', {'id': chambre.id}) }}" class="btn btn-info btn-sm">Voir</a>
                        <a href="{{ path('app_admin_chambre_edit', {'id': chambre.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucune chambre trouvée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ (page <= 1) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_chambre_index', {'page': page - 1, 'search': search}) }}">Précédent</a>
                </li>
                {% for i in 1..maxPages %}
                    <li class="page-item {{ (page == i) ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_admin_chambre_index', {'page': i, 'search': search}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {{ (page >= maxPages) ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_admin_chambre_index', {'page': page + 1, 'search': search}) }}">Suivant</a>
                </li>
            </ul>
        </nav>

        <div class="mt-4">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
