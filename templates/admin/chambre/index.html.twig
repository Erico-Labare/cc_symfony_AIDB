{% extends 'base.html.twig' %}

{% block title %}Chambre index{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Gestion des Chambres</h1>

        <a href="{{ path('app_admin_chambre_new') }}" class="btn btn-primary mb-3">Créer une nouvelle chambre</a>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Etage</th>
                    <th>Type</th>
                    <th>NombreLit</th>
                    <th>Hôtel</th>
                    <th>actions</th>
                </tr>
            </thead>
            <tbody>
            {% for chambre in chambres %}
                <tr>
                    <td>{{ chambre.id }}</td>
                    <td>{{ chambre.etage }}</td>
                    <td>{{ chambre.type }}</td>
                    <td>{{ chambre.nombreLit }}</td>
                    <td>{{ chambre.hotel.nom}}</td>
                    <td>
                        <a href="{{ path('app_admin_chambre_show', {'id': chambre.id}) }}" class="btn btn-info btn-sm">Voir</a>
                        <a href="{{ path('app_admin_chambre_edit', {'id': chambre.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">Aucune chambre trouvée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-4">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
