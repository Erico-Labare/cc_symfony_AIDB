{% extends 'base.html.twig' %}

{% block title %}Gestion des Chambres{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Gestion des chambres
        </h1>

        <p class="page-subtitle">
            Consultez, recherchez et gérez les chambres de vos hôtels.
        </p>

    </div>

    <div class="admin-toolbar">

        <div class="row g-3 align-items-end">

            <div class="col-lg-8">

                <label class="form-label">
                    Rechercher une chambre
                </label>

                <form method="GET" action="{{ path('app_admin_chambre_index') }}">

                    <input
                        type="text"
                        name="search"
                        class="form-control"
                        value="{{ search }}"
                        placeholder="Type ou étage">

                </form>

            </div>

            <div class="col-lg-2 d-grid">

                <button
                    formmethod="GET"
                    formaction="{{ path('app_admin_chambre_index') }}"
                    class="btn btn-primary">

                    <i class="bi bi-search me-2"></i>

                    Rechercher

                </button>

            </div>

            <div class="col-lg-2 d-grid">

                <a
                    href="{{ path('app_admin_chambre_new') }}"
                    class="btn btn-success">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nouvelle

                </a>

            </div>

        </div>

    </div>

    <table class="table admin-table align-middle">

        <thead>

            <tr>

                <th style="width:90px;">#</th>

                <th>Chambre</th>

                <th>Hôtel</th>

                <th>Étage</th>

                <th>Lits</th>

                <th class="text-center" style="width:170px;">Actions</th>

            </tr>

        </thead>

        <tbody>

        {% for chambre in chambres %}

            <tr>

                <td>

                    <span class="badge bg-primary">

                        #{{ chambre.id }}

                    </span>

                </td>

                <td>

                    <strong>{{ chambre.type }}</strong>

                </td>

                <td>

                    {{ chambre.hotel.nom }}

                </td>

                <td>

                    {{ chambre.etage }}

                </td>

                <td>

                    {{ chambre.nombreLit }}

                </td>

                <td class="text-center">

                    <div class="d-flex justify-content-center gap-2">

                        <a
                            href="{{ path('app_admin_chambre_show',{id:chambre.id}) }}"
                            class="btn btn-outline-primary btn-sm">

                            <i class="bi bi-eye"></i>

                        </a>

                        <a
                            href="{{ path('app_admin_chambre_edit',{id:chambre.id}) }}"
                            class="btn btn-outline-warning btn-sm">

                            <i class="bi bi-pencil-square"></i>

                        </a>

                        <button
                            type="button"
                            class="btn btn-outline-danger btn-sm delete-button"

                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"

                            data-action="{{ path('app_admin_chambre_delete',{id:chambre.id}) }}"

                            data-token="{{ csrf_token('delete' ~ chambre.id) }}"

                            data-message="Êtes-vous sûr de vouloir supprimer la chambre n°{{ chambre.id }} ?">

                            <i class="bi bi-trash"></i>

                        </button>

                    </div>

                </td>

            </tr>

        {% else %}

            <tr>

                <td colspan="6" class="text-center py-5">

                    <i class="bi bi-door-open fs-1 text-secondary"></i>

                    <br><br>

                    Aucune chambre trouvée.

                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

    <nav aria-label="Pagination">

        <ul class="pagination justify-content-center">

            <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_chambre_index',{
                        page:page-1,
                        search:search
                   }) }}">

                    Précédent

                </a>

            </li>

            {% for i in 1..maxPages %}

                <li class="page-item {{ page == i ? 'active' : '' }}">

                    <a class="page-link"
                       href="{{ path('app_admin_chambre_index',{
                            page:i,
                            search:search
                       }) }}">

                        {{ i }}

                    </a>

                </li>

            {% endfor %}

            <li class="page-item {{ page >= maxPages ? 'disabled' : '' }}">

                <a class="page-link"
                   href="{{ path('app_admin_chambre_index',{
                        page:page+1,
                        search:search
                   }) }}">

                    Suivant

                </a>

            </li>

        </ul>

    </nav>

    <div class="mt-4">

        <a
            href="{{ path('app_admin') }}"
            class="btn btn-outline-secondary">

            <i class="bi bi-arrow-left me-2"></i>

            Tableau de bord

        </a>

    </div>

</div>

{% endblock %}