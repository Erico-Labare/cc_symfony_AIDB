{% extends 'base.html.twig' %}

{% block title %}Chambre{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Détails de la Chambre</h1>

        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ chambre.id }}</td>
                </tr>
                <tr>
                    <th>Etage</th>
                    <td>{{ chambre.etage }}</td>
                </tr>
                <tr>
                    <th>Type</th>
                    <td>{{ chambre.type }}</td>
                </tr>
                <tr>
                    <th>NombreLit</th>
                    <td>{{ chambre.nombreLit }}</td>
                </tr>
                <tr>
                    <th>Hôtel</th>
                    <td>{{ chambre.hotel.nom }}</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <div>
                <a href="{{ path('app_admin_chambre_index') }}" class="btn btn-secondary">Retour à la liste</a>
                <a href="{{ path('app_admin_chambre_edit', {'id': chambre.id}) }}" class="btn btn-warning">Modifier</a>
            </div>
            {{ include('admin/chambre/_delete_form.html.twig') }}
        </div>
        <div class="mt-3">
            <a href="{{ path('app_admin') }}" class="btn btn-secondary">Retour à la page Admin</a>
        </div>
    </div>
{% endblock %}
