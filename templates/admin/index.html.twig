{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">Administration</h1>

    <div class="row">

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Hôtels
                    </h5>

                    <p class="card-text">
                        Gérer les hôtels.
                    </p>

                    <a
                        href="{{ path('app_hotel_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Chambres
                    </h5>

                    <p class="card-text">
                        Gérer les chambres.
                    </p>

                    <a
                        href="{{ path('app_chambre_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Comptes
                    </h5>

                    <p class="card-text">
                        Gérer les utilisateurs.
                    </p>

                    <a
                        href="{{ path('app_compte_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}