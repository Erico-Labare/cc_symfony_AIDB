{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1 class="mb-4">Administration</h1>

    <div class="row">

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Hôtels
                    </h5>

                    <p class="card-text">
                        Gérer les hôtels.
                    </p>

                    <a
                        href="{{ path('app_admin_hotel_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Chambres
                    </h5>

                    <p class="card-text">
                        Gérer les chambres.
                    </p>

                    <a
                        href="{{ path('app_admin_chambre_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Comptes
                    </h5>

                    <p class="card-text">
                        Gérer les utilisateurs (comptes de connexion).
                    </p>

                    <a
                        href="{{ path('app_admin_compte_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Clients
                    </h5>

                    <p class="card-text">
                        Gérer les informations des clients.
                    </p>

                    <a
                        href="{{ path('app_admin_client_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-3">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Réservations
                    </h5>

                    <p class="card-text">
                        Gérer les réservations des clients.
                    </p>

                    <a
                        href="{{ path('app_admin_reservation_index') }}"
                        class="btn btn-primary"
                    >
                        Accéder
                    </a>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-4">
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

</div>

{% endblock %}
