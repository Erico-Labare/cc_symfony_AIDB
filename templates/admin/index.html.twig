{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}

<div class="container">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Tableau de bord
        </h1>

        <p class="page-subtitle">
            Gérez les hôtels, chambres, clients, comptes et réservations.
        </p>

    </div>

    <div class="row g-4">

        <div class="col-xl-4 col-md-6">

            <div class="admin-card">

                <div class="admin-icon">
                    <i class="bi bi-building"></i>
                </div>

                <h3>Hôtels</h3>

                <p class="admin-count">
                    {{ hotelCount }}
                </p>

                <small>
                    hôtel(s) enregistré(s)
                </small>

                <a
                    href="{{ path('app_admin_hotel_index') }}"
                    class="btn btn-primary w-100 mt-4">

                    Gérer les hôtels

                </a>

            </div>

        </div>

        <div class="col-xl-4 col-md-6">

            <div class="admin-card">

                <div class="admin-icon">
                    <i class="bi bi-door-open"></i>
                </div>

                <h3>Chambres</h3>

                <p class="admin-count">
                    {{ chambreCount }}
                </p>

                <small>
                    chambre(s)
                </small>

                <a
                    href="{{ path('app_admin_chambre_index') }}"
                    class="btn btn-primary w-100 mt-4">

                    Gérer les chambres

                </a>

            </div>

        </div>

        <div class="col-xl-4 col-md-6">

            <div class="admin-card">

                <div class="admin-icon">
                    <i class="bi bi-people-fill"></i>
                </div>

                <h3>Clients</h3>

                <p class="admin-count">
                    {{ clientCount }}
                </p>

                <small>
                    client(s)
                </small>

                <a
                    href="{{ path('app_admin_client_index') }}"
                    class="btn btn-primary w-100 mt-4">

                    Gérer les clients

                </a>

            </div>

        </div>

        <div class="col-xl-4 col-md-6">

            <div class="admin-card">

                <div class="admin-icon">
                    <i class="bi bi-person-lock"></i>
                </div>

                <h3>Comptes</h3>

                <p class="admin-count">
                    {{ compteCount }}
                </p>

                <small>
                    compte(s)
                </small>

                <a
                    href="{{ path('app_admin_compte_index') }}"
                    class="btn btn-primary w-100 mt-4">

                    Gérer les comptes

                </a>

            </div>

        </div>

        <div class="col-xl-4 col-md-6">

            <div class="admin-card">

                <div class="admin-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>

                <h3>Réservations</h3>

                <p class="admin-count">
                    {{ reservationCount }}
                </p>

                <small>
                    réservation(s)
                </small>

                <a
                    href="{{ path('app_admin_reservation_index') }}"
                    class="btn btn-primary w-100 mt-4">

                    Gérer les réservations

                </a>

            </div>

        </div>

    </div>

    <div class="text-center mt-5">

        <a
            href="{{ path('app_home') }}"
            class="btn btn-outline-light">

            ← Retour au site

        </a>

    </div>

</div>

{% endblock %}