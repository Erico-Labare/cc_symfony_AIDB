<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Centrale de réservation{% endblock %}</title>

        {# Bootstrap CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}
    </head>
    
    
    <body class="d-flex flex-column min-vh-100">
        {# Navbar #}
        {% include 'partials/navbar.html.twig' %}

        {# Content #}
        <main class="container mt-4 flex-grow-1">
            {% block body %}{% endblock %}

            {% if is_granted('ROLE_ADMIN') %}

            <li class="nav-item mt-4 flex-grow-1 p-5 bg-light rounded alert alert-success badge">

                <a class="nav-link" href="{{ path('app_admin') }}">
                    Boutton de gestion de l'administration
                </a>

            </li>

            {% endif %}
        </main>
        
        {# Footer #}
        {% include 'partials/footer.html.twig' %}

        {# Bootstrap JS #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


        {% block javascripts %}
        {% endblock %}
    </body>


    
</html>
